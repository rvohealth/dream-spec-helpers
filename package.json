{
  "type": "module",
  "name": "@rvoh/dream-spec-helpers",
  "version": "2.3.0",
  "description": "dream orm spec helpers",
  "author": "RVO Health",
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/rvohealth/dream-spec-helpers.git"
  },
  "main": "./dist/cjs/src/index.js",
  "module": "./dist/esm/src/index.js",
  "types": "./dist/types/src/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/types/src/index.d.ts",
      "import": "./dist/esm/src/index.js",
      "require": "./dist/cjs/src/index.js"
    }
  },
  "files": [
    "tsconfig.json",
    "src/**/*",
    "dist/**/*"
  ],
  "scripts": {
    "build": "echo \"building dream-spec-helpers...\" && rm -rf dist && tsc -p ./tsconfig.cjs.build.json && tsc -p ./tsconfig.esm.build.json && echo '{\"type\":\"commonjs\"}' > dist/cjs/package.json",
    "format": "pnpm prettier . --write",
    "prepack": "pnpm build",
    "lint": "pnpm eslint --no-warn-ignored \"src/**/*.ts\" && pnpm prettier . --check"
  },
  "peerDependencies": {
    "@types/node": "*",
    "@types/pg": "*",
    "pg": "*"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@types/node": "^22.5.1",
    "@types/pg": "^8.11.8",
    "@typescript-eslint/parser": "^8.48.1",
    "eslint": "^9.39.1",
    "pg": "^8.12.0",
    "prettier": "^3.7.4",
    "ts-node": "^10.9.2",
    "typescript": "^5.5.4",
    "typescript-eslint": "^8.48.1",
    "vitest": "^4.0.10"
  },
  "packageManager": "pnpm@11.9.0+sha512.bd682d5d03fe525ef7c9fd6780c6884d1e756ac4c9c9fe00c538782824310dcf90e3ddc4f53835f06dfaebd5085e41855e0bcbb3b60de2ac5bbab89e5036f03b",
  "dependencies": {
    "commander": "^14.0.2",
    "dotenv": "^17.2.3",
    "pluralize-esm": "^9.0.5"
  }
}
